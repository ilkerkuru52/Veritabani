    {
      "parameters": {
        "jsCode": "// Groq cevaplarını birleştir\nconst summary = $('Groq — Özet').item.json.choices?.[0]?.message?.content || 'Özet alınamadı.';\nconst quiz    = $('Groq — Quiz').item.json.choices?.[0]?.message?.content || 'Quiz üretilemedi.';\nconst video   = $('Get YouTube Video').item.json;\nconst webhook = $('Webhook').item.json;\n\nconst title      = video.snippet?.title || 'Başlık yok';\nconst youtubeUrl = webhook.body?.youtubeUrl || '';\nconst channelTitle = video.snippet?.channelTitle || '';\n\n// ── Hafıza: özeti workflow static data'ya kaydet ──\n// Bu sayede sohbet webhook'u özete erişebilir\nconst staticData = $getWorkflowStaticData('global');\nstaticData.lastSummary  = summary;\nstaticData.lastTitle    = title;\nstaticData.lastUrl      = youtubeUrl;\nstaticData.chatHistory  = [];  // Yeni video → sohbet geçmişini sıfırla\n\nreturn [{ json: { summary, quiz, title, youtubeUrl, channelTitle, id: video.id } }];"
      },
      "id": "00e16c3f-73f0-4c9d-bc2f-d8f4f72bff30",
