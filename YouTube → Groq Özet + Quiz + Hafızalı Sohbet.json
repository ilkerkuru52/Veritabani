    {
      "parameters": {
        "jsCode": "const body      = items[0].json.body || items[0].json;\nconst message   = body.message || {};\nconst userText  = message.text || '';\nconst chatId    = message.chat?.id?.toString() || '';\nconst firstName = message.from?.first_name || 'Kullanıcı';\nconst isStart   = userText === '/start';\nreturn [{ json: { chatId, userText, firstName, isStart } }];"
      },
      "id": "e3046ffe-a186-44c0-bcc8-30f4130e0c08",
      "name": "Parse Telegram Message",
      "type": "n8n-nodes-base.code",
