    {
      "parameters": {
        "chatId": "={{ $json.chatId }}",
        "text": "=👋 Merhaba <b>{{ $json.firstName }}</b>!\n\nBen YouTube öğrenme asistanınım 🎓\n\nBir video analiz ettirdikten sonra buradan soru sorabilirsin — özeti ve konuyu hatırlıyorum!\n\n<i>Henüz video analiz edilmediyse önce webhook'a link gönder.</i>",
        "additionalFields": {
          "appendAttribution": false,
          "parse_mode": "HTML"
        }
      },
      "id": "5636933f-a87a-4c67-93c4-cdc9662f006c",
      "name": "Telegram — Hoş Geldin",
      "type": "n8n-nodes-base.telegram",
      "position": [
        672,
        592
      ],
      "typeVersion": 1.2,
      "webhookId": "7a56d2ac-e94b-4be1-8ac3-1583a0cbe86c"
    },
    {
      "parameters": {
        "jsCode": "// ── Static data'dan hafızayı oku ──\nconst staticData = $getWorkflowStaticData('global');\nconst summary     = staticData.lastSummary  || null;\nconst title       = staticData.lastTitle    || null;\nconst url         = staticData.lastUrl      || null;\nconst history     = staticData.chatHistory  || [];\n\nconst userText    = items[0].json.userText;\nconst chatId      = items[0].json.chatId;\n\n// ── Sistem promptu: özeti enjekte et ──\nlet systemPrompt = 'Sen bir eğitim asistanısın. Kullanıcı seninle YouTube videoları hakkında konuşuyor.\\n\\nKısa, anlaşılır, teşvik edici cevaplar ver. Türkçe konuş. Maksimum 3 paragraf.';\n\nif (summary && title) {\n  systemPrompt += `\\n\\n━━━ EN SON ANALİZ EDİLEN VİDEO ━━━\\nBaşlık: ${title}\\nURL: ${url}\\n\\nVİDEO ÖZETİ:\\n${summary}\\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\\n\\nKullanıcı bu video hakkında soru soruyorsa yukarıdaki özete dayanarak cevapla.`;\n}\n\n// ── Mesaj geçmişini hazırla (son 10 mesaj = 5 tur) ──\n// Her tur: {role:'user', content:...}, {role:'assistant', content:...}\nconst MAX_TURNS = 10; // 5 kullanıcı + 5 asistan\nconst recentHistory = history.slice(-MAX_TURNS);\n\n// ── Mevcut kullanıcı mesajını geçmişe ekle ──\nconst updatedHistory = [...history, { role: 'user', content: userText }];\n// Son MAX_TURNS+1 tut (yeni mesaj dahil)\nstaticData.chatHistory = updatedHistory.slice(-(MAX_TURNS + 1));\n\n// ── Groq'a gönderilecek messages dizisi ──\nconst messages = [\n  { role: 'system', content: systemPrompt },\n  ...recentHistory,\n  { role: 'user', content: userText }\n];\n\nreturn [{ json: { messages, chatId, userText } }];"
      },
