    {
      "parameters": {
        "jsCode": "// Groq'un cevabını geçmişe ekle\nconst reply = items[0].json.choices?.[0]?.message?.content || 'Cevap alınamadı.';\nconst chatId = $('Hafızadan Bağlamı Oluştur').item.json.chatId;\n\nconst staticData = $getWorkflowStaticData('global');\nconst history = staticData.chatHistory || [];\n\n// Asistan cevabını geçmişe ekle, son 10 tut\nstaticData.chatHistory = [...history, { role: 'assistant', content: reply }].slice(-10);\n\nreturn [{ json: { reply, chatId } }];"
      },
