        "jsCode": "const raw = items[0].json.concatenated_text || '';\nconst MAX = 12000;\nconst text = raw.length > MAX\n  ? raw.slice(0, MAX) + '\\n\\n[Transkript çok uzundu, ilk bölüm alındı]'\n  : raw;\nreturn [{ json: { ...items[0].json, trimmed_text: text } }];"
